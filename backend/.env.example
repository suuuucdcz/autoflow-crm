# AutoFlow CRM Backend — Environment Variables
# Copier ce fichier : cp .env.example .env

# Groq API (IA scoring)
GROQ_API_KEY=

# Port serveur
PORT=3000

# SMTP (notifications email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Slack webhook
SLACK_WEBHOOK_URL=

# Google OAuth2 (Gmail API)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth2 (Outlook) — optionnel
MS_CLIENT_ID=
MS_AUTHORITY=https://login.microsoftonline.com/common
